{
  "installCommand": "npm install -g pnpm && pnpm install --ignore-scripts",
  "buildCommand": "pnpm run build:frontend && rm -rf dist && cp -R artifacts/video-finder/dist dist",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "functions": {
    "api/**/*.{js,ts}": {
      "runtime": "@vercel/node@3",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}

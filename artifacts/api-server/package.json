{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "build:vercel": "node ../../scripts/build-vercel-api.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@esbuild/darwin-arm64": "^0.27.3",
    "@rollup/rollup-darwin-arm64": "4.60.3",
    "@supabase/supabase-js": "^2.106.0",
    "@tailwindcss/oxide-darwin-arm64": "4.3.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "axios": "^1.16.1",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "catalog:",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "lightningcss-darwin-arm64": "1.32.0",
    "multer": "^2.2.0",
    "node-fetch": "^3.3.2",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "playwright": "^1.61.0",
    "puppeteer-core": "^25.0.3",
    "uuid": "^14.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "catalog:",
    "@types/uuid": "^11.0.0",
    "@types/xlsx": "^0.0.36",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0"
  }
}

{
  "installCommand": "cd ../.. && npm install -g pnpm && pnpm install --ignore-scripts",
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
